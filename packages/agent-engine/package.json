{
  "name": "@ui-grid-ai/agent-engine",
  "version": "0.1.0",
  "description": "Core engine layer for AI agent orchestration with React AI SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "react-ai-sdk",
    "multi-model"
  ],
  "dependencies": {
    "ai": "^5.0.30",
    "@ai-sdk/openai": "^2.0.23",
    "@ai-sdk/anthropic": "^2.0.11",
    "groq-sdk": "^0.30.0",
    "@google/generative-ai": "^0.24.1",
    "zod": "^3.22.4",
    "nanoid": "^5.1.5",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}