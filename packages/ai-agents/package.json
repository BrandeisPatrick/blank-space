{
  "name": "@ui-grid-ai/ai-agents",
  "version": "0.1.0",
  "description": "AI agent system for UI Grid AI with provider abstraction and workflow orchestration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:local": "tsx examples/local-test.ts",
    "test:simple": "tsx examples/simple-test.ts",
    "demo": "tsx examples/live-demo.ts",
    "demo:simple": "npm run test:simple",
    "demo:server": "tsx examples/server-integration-example.ts",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "orchestration",
    "providers",
    "automation"
  ],
  "dependencies": {
    "@ui-grid-ai/agent-engine": "file:../agent-engine",
    "zod": "^3.22.4",
    "nanoid": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}