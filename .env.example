# Copy this file to .env and fill in your actual values

# Default AI Provider (xai, openai, anthropic, gemini, cohere, together)
AI_PROVIDER=xai

# X.AI Configuration (Primary for code generation)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-beta

# OpenAI Configuration (Primary for reasoning and prompt engineering)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_ORG_ID=

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# Cohere Configuration
COHERE_API_KEY=your_cohere_api_key_here
COHERE_MODEL=command

# Together AI Configuration
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Server Configuration
SERVER_PORT=3001
NODE_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:3001

# Developer Mode Configuration (Development Only)
VITE_ENABLE_DEVELOPER_MODE=true
VITE_DEVELOPER_PASSWORD=dev123