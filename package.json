{
  "name": "ui-grid-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/studio",
    "dev:api": "vercel dev --listen 3001",
    "dev": "npm-run-all -p dev:api dev:web",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "sync:env": "node scripts/sync-env.js",
    "sync:env:production": "node scripts/sync-env.js --env production"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vercel/node": "^5.3.22",
    "eslint": "^8.55.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vercel": "^47.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.23",
    "@ai-sdk/xai": "^2.0.16",
    "ai": "^5.0.33"
  },
  "eslintConfig": {
    "extends": [
      "./config/.eslintrc.json"
    ]
  },
  "prettier": "./config/.prettierrc"
}
