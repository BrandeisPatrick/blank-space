{
  "name": "ui-grid-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/studio",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:ai-cli": "npm run dev --workspace=packages/cli-interface",
    "ai-code": "npm run dev --workspace=packages/ai-coding-system",
    "build": "npm run build --workspaces",
    "build:ai-system": "npm run build --workspace=packages/agent-engine && npm run build --workspace=packages/react-reasoning && npm run build --workspace=packages/cli-interface && npm run build --workspace=packages/ai-coding-system",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.11",
    "@ai-sdk/google": "^2.0.12",
    "@ai-sdk/openai": "^2.0.23",
    "@monaco-editor/react": "^4.7.0",
    "@types/inquirer": "^9.0.9",
    "ai": "^5.0.33",
    "chalk": "^5.6.0",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "groq-sdk": "^0.30.0",
    "inquirer": "^12.9.4",
    "nanoid": "^5.1.5"
  },
  "eslintConfig": {
    "extends": [
      "./config/.eslintrc.json"
    ]
  },
  "prettier": "./config/.prettierrc"
}
