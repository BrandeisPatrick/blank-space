{
  "name": "ui-grid-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/studio",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "deploy:local": "node scripts/deploy-local.js",
    "deploy:preview": "node scripts/deploy-local.js preview",
    "build:local": "node scripts/deploy-local.js build",
    "serve:local": "node scripts/serve-local.js",
    "sync:env": "node scripts/sync-env.js",
    "sync:env:production": "node scripts/sync-env.js --env production"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.11",
    "@ai-sdk/google": "^2.0.12",
    "@ai-sdk/openai": "^2.0.23",
    "@ai-sdk/xai": "^2.0.16",
    "@monaco-editor/react": "^4.7.0",
    "@types/inquirer": "^9.0.9",
    "ai": "^5.0.33",
    "chalk": "^5.6.0",
    "commander": "^14.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "groq-sdk": "^0.30.0",
    "helmet": "^8.1.0",
    "inquirer": "^12.9.4",
    "nanoid": "^5.1.5"
  },
  "eslintConfig": {
    "extends": [
      "./config/.eslintrc.json"
    ]
  },
  "prettier": "./config/.prettierrc"
}
