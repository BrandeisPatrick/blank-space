# Production environment for testing
NODE_ENV=production
SERVER_PORT=3001

# API Keys - Set these in Vercel dashboard, DO NOT commit real keys
GROQ_API_KEY=your_groq_api_key_here

# Default AI Provider
AI_PROVIDER=groq

# API Configuration - Leave empty for Vercel, will use relative paths
VITE_API_BASE_URL=

# Developer Mode Configuration (DISABLED IN PRODUCTION)
VITE_ENABLE_DEVELOPER_MODE=false
# VITE_DEVELOPER_PASSWORD is intentionally not set in production